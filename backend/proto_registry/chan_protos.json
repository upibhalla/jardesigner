    {
      "id": "Na_HH",
      "name": "Na_HH",
      "source": "Hodgkin & Huxley 1952",
      "description": "Classic Hodgkin-Huxley sodium channel",
      "topTen": true,
      "source_type": "builtin",
      "builtin_fn": "make_HH_Na()",
      "details": {
        "full_description": "Sodium channel with m³h gating kinetics as originally described for the squid giant axon. Fast activation, fast inactivation.",
        "parameters": {
          "Ek":   { "value": "0.045",  "units": "V" },
          "Gbar": { "value": "0.12",   "units": "S/m²" }
        },
        "references": [
          { "text": "Hodgkin AL & Huxley AF (1952). A quantitative description of membrane current and its application to conduction and excitation in nerve. J Physiol 117:500-544.", "url": "https://pubmed.ncbi.nlm.nih.gov/12991237/" }
        ]
      }
    },
