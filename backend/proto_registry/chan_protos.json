      "topTen": true,
      "source_type": "builtin",
      "builtin_fn": "make_Ca_conc()",
      "details": {
        "full_description": "Models intracellular calcium concentration as a shell with exponential decay. Driven by Ca channel currents. Required when using Ca-activated channels (K_AHP, K_C)."
